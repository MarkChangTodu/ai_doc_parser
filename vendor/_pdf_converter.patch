+# Threshold above which the input PDF stream is spilled to a temp file on disk
+# instead of being held in a BytesIO. This avoids holding 1-2x the file size in
+# RAM for large PDFs (which on WSL can trigger OOM / host freezes).
+_SPOOL_MAX_SIZE = 10 * 1024 * 1024  # 10 MiB
+
+
+def _make_progress(total: int, desc: str = "Converting PDF") -> Callable[[int], None]:
+    """Return a callable ``update(current)`` that renders a page-level progress bar.
+
+    - Uses ``tqdm`` when available.
+    - Falls back to a simple ``\r``-based line on stderr when stderr is a TTY.
+    - Becomes a no-op when stderr is not a TTY (so library / pipeline use stays clean).
+
+    The returned callable has a ``.close()`` method to finalize the bar.
+    """
+    # No-op when not interactive
+    if not getattr(sys.stderr, "isatty", lambda: False)():
+        def _noop(current: int) -> None:
+            return None
+
+        _noop.close = lambda: None  # type: ignore[attr-defined]
+        return _noop  # type: ignore[return-value]
+
+    try:
+        from tqdm import tqdm  # type: ignore
+
+        bar = tqdm(total=total, desc=desc, unit="page", file=sys.stderr, leave=False)
+
+        def _update(current: int) -> None:
+            delta = current - bar.n
+            if delta > 0:
+                bar.update(delta)
+
+        _update.close = bar.close  # type: ignore[attr-defined]
+        return _update  # type: ignore[return-value]
+    except ImportError:
+        pass
+
+    # Stdlib fallback
+    def _update(current: int) -> None:
+        pct = (current * 100 // total) if total else 100
+        sys.stderr.write(f"\r{desc}: {current}/{total} ({pct}%)")
+        sys.stderr.flush()
+
+    def _close() -> None:
+        sys.stderr.write("\n")
+        sys.stderr.flush()
+
+    _update.close = _close  # type: ignore[attr-defined]
+    return _update  # type: ignore[return-value]
+
 # Pattern for MasterFormat-style partial numbering (e.g., ".1", ".2", ".10")
